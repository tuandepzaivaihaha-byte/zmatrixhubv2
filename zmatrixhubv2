local TweenService = game:GetService("TweenService")

-- HÀM BAY AN TOÀN (Thay thế cho CFrame trực tiếp)
local function toPos(targetCFrame)
    local distance = (hrp.Position - targetCFrame.Position).Magnitude
    local speed = 100 -- Tốc độ bay (chỉnh cao hơn nếu muốn nhanh, nhưng dễ bị ban)
    local info = TweenInfo.new(distance / speed, Enum.EasingStyle.Linear)
    
    local tween = TweenService:Create(hrp, info, {CFrame = targetCFrame})
    tween:Play()
    return tween
end

-- Sửa lại logic trong Main Loop
task.spawn(function()
    while task.wait(0.5) do
        if autoFarm then
            local level = getMyLevel()
            local info = questData[1]
            
            for _, v in ipairs(questData) do
                if level >= v.Level then info = v end
            end

            if not hasQuest() then
                targetMob = nil
                local npc = workspace:FindFirstChild(info.NPC, true)
                if npc and npc:FindFirstChild("HumanoidRootPart") then
                    -- Bay tới NPC
                    local tween = toPos(npc.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3))
                    tween.Completed:Wait() -- Đợi bay tới nơi mới bấm
                    
                    task.wait(0.2)
                    VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                    task.wait(0.1)
                    VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                    -- LƯU Ý: Nếu game hiện bảng UI, bạn cần thêm code click nút Accept ở đây
                end
            else
                -- Đã có Quest
                targetMob = getMob(info.Mob)
                
                if not targetMob then
                    -- Nếu không thấy quái, bay tới bãi quái (đã cộng thêm độ cao để tránh kẹt đất)
                    toPos(CFrame.new(info.Pos + Vector3.new(0, 20, 0)))
                end
            end
        end
    end
end)
